<Window x:Class="Valger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Оборудование" Height="600" Width="1300">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с фильтрами -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" x:Name="filterPanel">
            <TextBox x:Name="searchBox" Width="200" Margin="5" 
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="cb_manufacturer" Width="200" Margin="5"
                      SelectionChanged="Manufacturer_SelectionChanged"/>

            <Button Content="Сортировать по количеству (↑)" Width="250" 
                    Margin="5" Click="SortByQuantityAscending_Click"/>
            <Button Content="Сортировать по количеству (↓)" Width="250" 
                    Margin="5" Click="SortByQuantityDescending_Click"/>
        </StackPanel>

        <!-- Правая панель с кнопками -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,5,0,0">
            <TextBlock x:Name="tb_userInfo" Margin="5" VerticalAlignment="Center"/>

            <Button x:Name="bt_rental" Content="Аренда" Margin="5" 
                    Click="bt_rental_Click"/>
            <Button x:Name="bt_create" Content="Добавить" Margin="5" 
                    Click="bt_create_Click"/>
            <Button x:Name="bt_delete" Content="Удалить" Margin="5" 
                    Click="bt_delete_Click"/>
            <Button x:Name="bt_exit" Content="Выйти" Margin="5" 
                    Click="bt_exit_Click"/>
        </StackPanel>

        <!-- Список оборудования -->
        <ListView Grid.Row="1" x:Name="lv_equipment" 
                  MouseDoubleClick="lv_equipment_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Window>