<Window x:Class="Valger.Windows.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Valger.Windows"
        mc:Ignorable="d"
        Title="OrdersWindow" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- Кнопки, доступные только для администратора -->
            <Button Name="bt_addRental" Content="Добавить аренду" Margin="5" Padding="10 5" Click="bt_addRental_Click"/>
            <Button Name="bt_deleteRental" Content="Удалить" Margin="5" Padding="10 5" Click="bt_deleteRental_Click"/>
            <Button Name="bt_close" Content="Закрыть" Margin="5" Padding="10 5" Click="bt_close_Click"/>
        </StackPanel>

        <!-- Контейнер для карточек аренды с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <!-- WrapPanel для размещения карточек в 2 колонки -->
            <WrapPanel Name="wp_rentals" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
</Window>
